def load_all_logs():
    logs_path = Path("flight_logs")
    logs = []
    
    if logs_path.exists():
        for f in logs_path.glob("*.jsonl"):
            try:
                with open(f) as fl:
                    for line in fl:
                        try:
                            logs.append(json.loads(line.strip()))
                        except:
                            pass
            except:
                pass
    
    return logs

