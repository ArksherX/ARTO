        st.markdown(f"""
        <div class="summary-card {color}">
        <div class="card-label">Execution Decision</div>
        <h2>{decision.action.value.upper()}</h2>
        <p><b>Risk Magnitude:</b> <span class="metric-val">{decision.risk_score}/100</span></p>
        <p><b>Policy Context:</b> {decision.reasoning}</p>
        </div>
        """, unsafe_allow_html=True)

# ============================================================================
# MODE 4: BACKDOOR DETECTOR
# ============================================================================
elif mode == "Backdoor Detector":
    st.header("🔬 Hybrid Backdoor Detector & Red Team Lab")
    detector = HybridBackdoorDetector()
    
    def run_detection(text):
        for method_name in ['scan', 'analyze', 'detect', '__call__']:
            method = getattr(detector, method_name, None)
            if callable(method): 
                res = method(text)
                if isinstance(res, dict): return res
        return {"backdoor_detected": False, "confidence": 0, "reason": "No valid detection method found"}

    with st.expander("🛠️ Custom Trigger Registry"):
        new_trigger = st.text_input("Register New Trigger Phrase (IOC)")
        if st.button("Save to Registry") and new_trigger:
            st.session_state.custom_registry.append(new_trigger)
            st.success("IOC Registered.")
        if st.session_state.custom_registry:
            st.code("\n".join(st.session_state.custom_registry))

    st.subheader("📁 Threat Intel Feed (Batch Scan)")
    uploaded_file = st.file_uploader("Upload Backdoor Dataset (CSV)", type=["csv"])
    if uploaded_file and st.toggle("Enable Continuous Testing Mode"):
        df = pd.read_csv(uploaded_file)
        col = 'prompt' if 'prompt' in df.columns else df.columns[0]
        threats = 0
        for text in df[col].astype(str):
            res = run_detection(text)
            is_ioc = any(ioc.lower() in text.lower() for ioc in st.session_state.custom_registry)
            if res.get('backdoor_detected') or is_ioc: threats += 1
        st.metric("Dataset Detection Coverage", f"{(threats/len(df))*100:.1f}%")

    st.markdown("---")
    st.subheader("🎯 Manual Backdoor Analysis")
    test_text = st.text_area("Manual Test Input", "Enter suspicious payload...")
    if st.button("🔍 Analyze Text", type="primary"):
        res = run_detection(test_text)
        is_ioc_match = any(ioc.lower() in test_text.lower() for ioc in st.session_state.custom_registry)
        is_detected = res.get('backdoor_detected') or is_ioc_match
        color = "risk-high" if is_detected else "risk-low"
        status_text = "🚨 BACKDOOR DETECTED" if is_detected else "✅ CLEAN"
        confidence = res.get('confidence', 100 if is_ioc_match else 0)
        reasoning = res.get('reason', 'Trigger match found in custom IOC registry' if is_ioc_match else 'No suspicious patterns identified.')

        st.markdown(f"""
            <div class="summary-card {color}">
                <div class="card-label">Detection Result</div>
                <h2>{status_text}</h2>
                <p><b>Confidence:</b> <span class="metric-val">{confidence}%</span></p>
                <p><b>Heuristic Insight:</b> {reasoning}</p>
            </div>
        """, unsafe_allow_html=True)

# ============================================================================
