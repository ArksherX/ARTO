# ============================================================================
# 🎯 OWASP THREAT MATRIX
# ============================================================================

class OWASPThreatMapper:
    CAPABILITY_TO_THREATS = {
        "execution": {
            "threats": ["ASI05: Unexpected Code Execution", "LLM01: Prompt Injection", "LLM04: Data and Model Poisoning"],
            "severity": "CRITICAL",
            "attack_scenario": "Command Injection & Code Execution",
            "keywords": ["shell", "terminal", "exec", "run", "execute", "command", "bash", "powershell", "subprocess"]
        },
        "database": {
            "threats": ["ASI02: Tool Misuse and Exploitation", "LLM05: Improper Output Handling", "LLM02: Sensitive Information Disclosure"],
            "severity": "HIGH",
            "attack_scenario": "SQL Injection & Data Exfiltration",
            "keywords": ["sql", "db", "query", "postgres", "mysql", "mongodb", "database", "orm", "sqlalchemy"]
        },
        "filesystem": {
            "threats": ["ASI01: Agent Goal Hijack", "ASI03: Identity and Privilege Abuse", "LLM06: Excessive Agency"],
            "severity": "HIGH",
            "attack_scenario": "Path Traversal & Data Theft",
            "keywords": ["read", "write", "file", "path", "os", "filesystem", "directory", "folder", "upload", "download"]
        },
        "communication": {
            "threats": ["ASI09: Human-Agent Trust Exploitation", "ASI07: Insecure Inter-Agent Communication", "LLM03: Supply Chain Vulnerabilities"],
            "severity": "MEDIUM",
            "attack_scenario": "Social Engineering & Trust Exploitation",
            "keywords": ["mail", "email", "slack", "send", "notify", "webhook", "api", "http", "request", "post"]
        },
        "retrieval": {
            "threats": ["ASI06: Memory and Context Poisoning", "LLM08: Vector and Embedding Weaknesses", "LLM09: Misinformation & Overreliance"],
            "severity": "MEDIUM",
            "attack_scenario": "RAG Poisoning & Context Manipulation",
            "keywords": ["vector", "rag", "search", "pinecone", "weaviate", "chroma", "embedding", "index", "retrieval"]
        },
        "authentication": {
            "threats": ["ASI03: Identity and Privilege Abuse", "ASI10: Rogue Agents", "LLM02: Sensitive Information Disclosure"],
            "severity": "CRITICAL",
            "attack_scenario": "Credential Theft & Privilege Escalation",
            "keywords": ["auth", "token", "jwt", "oauth", "credential", "password", "key", "secret", "api_key"]
        },
        "network": {
            "threats": ["LLM10: Unbounded Consumption", "ASI08: Cascading Failures", "ASI02: Tool Misuse and Exploitation"],
            "severity": "HIGH",
            "attack_scenario": "SSRF & External Service Abuse",
            "keywords": ["http", "https", "url", "request", "fetch", "curl", "wget", "download", "upload", "socket"]
        }
    }
    
    @staticmethod
    def map_tools_to_attacks(tool_analysis: list) -> dict:
        attack_plan = {
            "targeted_tools": [],
            "total_attack_vectors": 0,
            "risk_score": 0,
            "owasp_threats_mapped": 0,
            "tool_attack_map": {}
        }
        
        all_threats = set()
        
        for tool_data in tool_analysis:
            tool_name = tool_data['tool']
            capabilities = tool_data['capabilities']
            tool_attacks = []
            
            for capability in capabilities:
                if capability in OWASPThreatMapper.CAPABILITY_TO_THREATS:
                    config = OWASPThreatMapper.CAPABILITY_TO_THREATS[capability]
                    for threat in config["threats"]:
                        tool_attacks.append({
                            "capability": capability,
                            "threat": threat,
                            "severity": config["severity"],
                            "scenario": config["attack_scenario"]
                        })
                        all_threats.add(threat)
            
            if tool_attacks:
                attack_plan["tool_attack_map"][tool_name] = {
                    "original_analysis": tool_data,
                    "targeted_attacks": tool_attacks,
                    "attack_count": len(tool_attacks)
                }
                attack_plan["targeted_tools"].append(tool_name)
                attack_plan["total_attack_vectors"] += len(tool_attacks)
        
        severity_weights = {"CRITICAL": 100, "HIGH": 70, "MEDIUM": 50, "LOW": 30}
        total_risk = 0
        threat_count = 0
        
        for tool_name, data in attack_plan["tool_attack_map"].items():
            for attack in data["targeted_attacks"]:
                total_risk += severity_weights.get(attack["severity"], 30)
                threat_count += 1
        
        if threat_count > 0:
            attack_plan["risk_score"] = total_risk / threat_count
        
        attack_plan["owasp_threats_mapped"] = len(all_threats)
        attack_plan["mapped_threats"] = list(all_threats)
        
        return attack_plan

# ============================================================================
# 🎯 AGENT CONTEXT & EVENT LOGGING
# ============================================================================

def initialize_agent_context():
    if 'agent_context' not in st.session_state:
        st.session_state.agent_context = {
            "discovered_tools": [],
            "tool_analysis": [],
            "attack_plan": None,
            "last_scan_time": None,
            "security_events": [],
            "scan_count": 0
        }

def add_security_event(event_type: str, tool_name: str, details: dict):
    initialize_agent_context()
    
    event = {
        "id": hashlib.md5(f"{event_type}_{tool_name}_{datetime.now().isoformat()}".encode()).hexdigest()[:8],
        "type": event_type,
        "tool": tool_name,
        "timestamp": datetime.now().isoformat(),
        "details": details
    }
    
    st.session_state.agent_context["security_events"].append(event)
    
    # 🎯 LOG TO VESTIGIA
    agent_id = details.get("agent_id", f"sim_{tool_name.replace('.', '_')}")
    risk_score = details.get("risk_score", 0)
    
    if event_type == "tool_discovery":
        vestigia.log_scan_complete(
            agent_id=agent_id,
            tool=tool_name,
            decision="ALLOW" if risk_score < 75 else "BLOCK",
            risk_score=risk_score,
            reasoning=f"Tool discovery: {details.get('tools_discovered', 0)} tools, {details.get('owasp_threats', 0)} OWASP threats"
        )
    elif event_type == "attack_detected":
        threat = details.get("threat", "unknown")
        vestigia.log_threat_detected(
            agent_id=agent_id,
            tool=tool_name,
            threat_type=threat,
            confidence=int(risk_score)
        )
    elif event_type == "policy_violation":
        vestigia.log_policy_violation(
            agent_id=agent_id,
            tool=tool_name,
            violation_type=details.get("violation_type", "Unknown violation"),
            severity="CRITICAL" if risk_score > 75 else "HIGH"
        )
    
    # Save to flight logs
    logs_path = Path("flight_logs")
    logs_path.mkdir(exist_ok=True)
    log_file = logs_path / f"simulation_{datetime.now().strftime('%Y%m%d')}.jsonl"
    
    log_entry = {
        "agent_id": agent_id,
        "event_type": event_type,
        "tool_targeted": tool_name,
        "risk_score": risk_score,
        "timestamp": datetime.now().isoformat(),
        "details": json.dumps(details),
        "source": "adversarial_simulation",
        "threat": details.get("threat", "unknown"),
        "is_simulation": True
    }
    
    try:
        with open(log_file, 'a') as f:
            f.write(json.dumps(log_entry) + '\n')
    except Exception as e:
        pass
    
    return event

# ============================================================================
# 🎯 TOOL DISCOVERY
# ============================================================================

def identify_tool_vulnerabilities(tool_name: str) -> dict:
    t_lower = tool_name.lower()
    detected_capabilities = []
    all_vulnerabilities = []
    max_severity = "LOW"
    severity_scores = {"CRITICAL": 90, "HIGH": 70, "MEDIUM": 50, "LOW": 30}
    
    for capability, config in OWASPThreatMapper.CAPABILITY_TO_THREATS.items():
        if any(keyword in t_lower for keyword in config["keywords"]):
            detected_capabilities.append(capability)
            all_vulnerabilities.extend(config["threats"])
            
            if severity_scores[config["severity"]] > severity_scores[max_severity]:
                max_severity = config["severity"]
    
    unique_vulnerabilities = list(set(all_vulnerabilities))
    
    base_risk = severity_scores.get(max_severity, 30)
    capability_multiplier = min(len(detected_capabilities) * 0.15, 0.3)
    risk_score = min(base_risk + (base_risk * capability_multiplier), 100)
    
    return {
        'vulnerabilities': unique_vulnerabilities,
        'capabilities': detected_capabilities,
        'severity': max_severity,
        'risk_score': int(risk_score)
    }

def discover_agent_tools(agent_config: dict) -> list:
    default_tools = [
        "sql_connector.py",
        "terminal_exec.py",
        "file_manager.py",
        "email_gateway.py",
        "vector_sync.py"
    ]
    
    custom_tools = agent_config.get('custom_tools', [])
    if custom_tools:
        default_tools.extend(custom_tools)
    
    return default_tools

