elif mode == "Complete Stack Demo":
    st.header("🛡️ Complete Security Stack")
    
    col1, col2 = st.columns(2)
    
    with col1:
        agent_id = st.text_input("Agent ID", "agent_demo_001")
        tool_name = st.text_input("Tool Name", "read_file")
        original_goal = st.text_area("Original Goal", "Analyze log files")
    
    with col2:
        reasoning_chain = st.text_area("Reasoning Chain", "User requested analysis\nRead log files\nGenerate report")
        parameters = st.text_area("Parameters (JSON)", '{"path": "/var/log/app.log"}')
    
    if st.button("🚀 Evaluate & Execute", type="primary", use_container_width=True):
        stack = CompleteSecurityStack()
        
        # Get values from sidebar
        if 'enable_mcp' in locals():
            stack.enable_mcp_sentry = enable_mcp
        if 'enable_sandbox' in locals():
            stack.enable_sandbox = enable_sandbox
        
        try:
            params = json.loads(parameters)
        except:
            params = {"path": parameters}
        
        action = AgentAction(
            agent_id=agent_id,
            tool_name=tool_name,
