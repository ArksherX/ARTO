                agent_id=f"{provider}_{model}",
                tool="security_scanner",
                prompt_hash=scan_hash
            )
            
            config = ScanConfig(scan_llm_threats=True, scan_agentic_threats=is_agent)
            scanner = VerityFluxScanner(application_name=f"{provider}/{model}", config=config)
            report = scanner.scan_all(target)
            
            # Tool analysis
            tool_analysis = []
            all_detected_vulnerabilities = []
            vulnerability_instances = 0
            vulnerability_instances = 0
            vulnerability_instances = 0
            
