                        tool_analysis.append({'tool': tool, **analysis})
                        all_detected_vulnerabilities.extend(analysis["vulnerabilities"])
                        vulnerability_instances += len(analysis["vulnerabilities"])
                        vulnerability_instances += len(analysis['vulnerabilities'])
                        vulnerability_instances += len(analysis['vulnerabilities'])
            
            unique_vulnerabilities = list(set(all_detected_vulnerabilities))
            
            # Create attack plan
            if has_tools and tool_analysis:
                attack_plan = OWASPThreatMapper.map_tools_to_attacks(tool_analysis)
                
                st.session_state.agent_context.update({
                    "discovered_tools": [t['tool'] for t in tool_analysis],
                    "tool_analysis": tool_analysis,
                    "attack_plan": attack_plan,
                    "last_scan_time": datetime.now().isoformat(),
                    "scan_count": st.session_state.agent_context.get("scan_count", 0) + 1
                })
                
                add_security_event(
                    "tool_discovery",
                    "security_scan",
                    {
                        "agent_id": f"{provider}_{model}",
                        "tools_discovered": len(tool_analysis),
                        "attack_vectors_mapped": attack_plan["total_attack_vectors"],
                        "owasp_threats": attack_plan["owasp_threats_mapped"],
                        "risk_score": attack_plan["risk_score"]
                    }
                )
            
            # 🎯 LOG SCAN COMPLETION TO VESTIGIA
            vestigia.log_scan_complete(
                agent_id=f"{provider}_{model}",
                tool="security_scanner",
                decision="COMPLETE",
                risk_score=report.overall_risk_score,
                reasoning=f"Scan complete: {len(unique_vulnerabilities)} threats detected"
            )
            
            st.session_state.scan_history.append({
                'timestamp': report.scan_timestamp.isoformat(),
                'target': f"{provider}/{model}",
                'risk_score': report.overall_risk_score,
                'threats': len(unique_vulnerabilities)
            })
            
            st.success("✅ Scan Complete!")
            
            # Show handshake status
            if has_tools and tool_analysis:
                st.markdown(f"""
                <div class="info-note">
                <strong>🎯 COMPLETE OWASP HANDOFF ESTABLISHED!</strong><br>
                • Discovered <strong>{len(tool_analysis)} tools</strong><br>
                • Mapped to <strong>{attack_plan['total_attack_vectors']} attack vectors</strong><br>
                • Covering <strong>{attack_plan['owasp_threats_mapped']} OWASP threats</strong><br>
                • <span style="color: #2ecc71;">✅ Events logged to Vestigia</span><br>
                Switch to "Adversarial Simulation Lab" for testing
                </div>
                """, unsafe_allow_html=True)
            
            # Metrics
            c1, c2, c3, c4 = st.columns(4)
            c1.metric("Risk Score", f"{report.overall_risk_score:.1f}/100")
            c2.metric("Unique Threats", len(unique_vulnerabilities))
            c3.metric("Tools Found", len(tool_analysis) if has_tools else 0)
            c4.metric("OWASP Coverage", attack_plan.get('owasp_threats_mapped', 0) if has_tools and tool_analysis else 0)
            
            # Tool analysis display
            if has_tools and tool_analysis:
                st.markdown("---")
                st.subheader("🛠️ Dynamic Tool Intelligence")
                
                tool_analysis.sort(key=lambda x: x['risk_score'], reverse=True)
                t_cols = st.columns(3)
                
                for idx, tool_data in enumerate(tool_analysis):
                    with t_cols[idx % 3]:
                        severity_class = f"risk-{tool_data['severity'].lower()}"
                        st.markdown(f"""
                        <div class="summary-card {severity_class}">
                        <span class="card-label">Tool Component</span><br>
                        <code style="color: #00ffcc; font-size: 0.9em;">{tool_data['tool']}</code><br>
                        <div style="margin-top: 8px;">
                        <span class="severity-{tool_data['severity'].lower()}">
                        ⚠ {tool_data['severity']} RISK
                        </span><br>
                        <span style="font-size: 0.8em; color: #aaa;">
                        Score: {tool_data['risk_score']}/100
                        </span>
                        </div>
                        <div style="margin-top: 10px;">
                        <span class="card-label">Capabilities</span><br>
                        """, unsafe_allow_html=True)
                        
                        # Show capability badges
                        for cap in tool_data['capabilities']:
                            st.markdown(f'<span class="capability-badge">{cap}</span>', unsafe_allow_html=True)
                        
                        # Show OWASP coverage badge
                        threat_count = len(tool_data['vulnerabilities'])
                        st.markdown(f'<span class="owasp-badge">🛡️ {threat_count} threats</span>', unsafe_allow_html=True)
                        st.markdown("</div></div>", unsafe_allow_html=True)
                
                st.markdown("---")
                st.subheader("🕵️ Active Threat Intelligence")
                
                # Show OWASP threat matrix
                if unique_vulnerabilities:
                    st.markdown(f"""
                    <div class="info-note">
                    <strong>🎯 COMPLETE OWASP THREAT INTELLIGENCE</strong><br>
                    Found <strong>{vulnerability_instances} vulnerability instances</strong> across {len(tool_analysis) if has_tools else 'components'}.<br>
                    Consolidated into <strong>{len(unique_vulnerabilities)} unique OWASP threat patterns</strong>:
                    </div>
                    """, unsafe_allow_html=True)
                    
                    # Display ALL threats in an expandable section
                    with st.expander(f"🔍 View All {len(unique_vulnerabilities)} Threats", expanded=True):
                        # Group threats by severity
                        threats_by_severity = {
                            "CRITICAL": [],
                            "HIGH": [],
                            "MEDIUM": [],
                            "LOW": []
                        }
                        
                        for vuln in unique_vulnerabilities:
                            if vuln in UVKB:
                                data = UVKB[vuln]
                                severity = data.get('base_severity', 'MEDIUM')
                                threats_by_severity[severity].append((vuln, data))
                        
                        # Display by severity order
                        for severity in ["CRITICAL", "HIGH", "MEDIUM", "LOW"]:
                            if threats_by_severity[severity]:
                                severity_emoji = "🔴" if severity == "CRITICAL" else "🟠" if severity == "HIGH" else "🟡" if severity == "MEDIUM" else "🟢"
                                st.subheader(f"{severity_emoji} {severity} ({len(threats_by_severity[severity])})")
                                
                                for vuln, data in threats_by_severity[severity]:
                                    st.markdown(f"**{vuln}**")
                                    st.markdown(f"*Impact:* {data['impact']}")
                                    st.markdown(f"*Remediation:* {data['remediation']}")
                                    st.caption(f"Category: {data['category']}")
                                    st.markdown("---")

