# MODE 2: COGNITIVE FIREWALL
# ============================================================================

elif mode == "Cognitive Firewall":
    st.header("🧠 Cognitive Firewall")
    
    col1, col2 = st.columns(2)
    
    with col1:
        agent_id = st.text_input("Agent ID", "agent_001")
        tool_name = st.text_input("Tool Name", "delete_database")
        original_goal = st.text_area("Original Goal", "Optimize database performance")
    
    with col2:
        reasoning_chain = st.text_area("Reasoning Chain", "Database is slow\nLogs taking space\nDelete to optimize")
        parameters = st.text_area("Parameters (JSON)", '{"table": "users"}')
        environment = st.selectbox("Environment", ["development", "staging", "production"])
    
    if st.button("🔍 Evaluate Action", type="primary", use_container_width=True):
        firewall = CognitiveFirewall()
        
        try:
            params = json.loads(parameters)
        except:
            params = {"raw": parameters}
        
        action = AgentAction(
            agent_id=agent_id,
            tool_name=tool_name,
            parameters=params,
            reasoning_chain=reasoning_chain.split('\n'),
            original_goal=original_goal,
            context={'environment': environment}
        )
        
        decision = firewall.evaluate(action)
        
        st.markdown("---")
        st.header("🎯 Firewall Decision")
        
        # Show tier badge
        tier = decision.context.get('tier', 'UNKNOWN')
        tier_colors = {
            'CRITICAL': '🔴',
            'HIGH': '🟠',
            'MEDIUM': '🟡',
            'LOW': '🟢'
        }
        
        st.subheader(f"{tier_colors.get(tier, '⚪')} Risk Tier: {tier}")
        
        d1, d2, d3 = st.columns(3)
        
        with d1:
            if decision.action.value == 'allow':
                st.success(f"✅ {decision.action.value.upper()}")
            elif decision.action.value == 'block':
                st.error(f"🚨 {decision.action.value.upper()}")
            elif decision.action.value == 'require_approval':
                st.warning(f"⚠️ REQUIRES APPROVAL")
            else:
                st.info(f"📊 {decision.action.value.upper()}")
        
        d2.metric("Risk Score", f"{decision.risk_score:.1f}/100")
        d3.metric("Confidence", f"{decision.confidence:.1f}%")
        
        st.write(f"**Reasoning:** {decision.reasoning}")

