# ============================================================================

elif mode == "Adversarial Simulation Lab":
    st.header("🎯 Red vs Blue: Adversarial Testing Framework")
    
    # 🎯 Get agent context
    ctx = st.session_state.agent_context
    has_targeted_tools = ctx.get("tool_analysis") and len(ctx["tool_analysis"]) > 0
    
    # Main layout
    main_col1, main_col2 = st.columns([2, 1])
    
    with main_col1:
        with st.expander("ℹ️ How This Works", expanded=True):
            st.markdown("""
            **🎯 ULTIMATE: Complete OWASP 2025 Testing Framework**
            
            **The Security Scan → Simulation Connection:**
            
            1. **Security Scan** discovers tools and maps to OWASP threats
            2. **OWASP Matrix** maps capabilities to ALL 20 threats
            3. **ARTEMIS** generates semantic payloads for specific threats
            4. **Cognitive Firewall** evaluates and blocks attacks
            5. **SOC Integration** logs events with OWASP threat context
            
            **Testing Modes:**
            - **🎯 Targeted**: Uses discovered tools with specific OWASP threats
            - **🌐 CTF**: Traditional challenge-based testing
            
            **Result:** Complete security validation against OWASP 2025 framework.
            """)
    
    with main_col2:
        # Quick status panel
        if has_targeted_tools:
            attack_plan = ctx.get("attack_plan", {})
            st.markdown(f"""
            <div style="background-color: #1a1c23; padding: 15px; border-radius: 5px; border: 2px solid #2ecc71;">
            <h4 style="color: #2ecc71; margin-top: 0;">🎯 HANDOFF ACTIVE</h4>
            <p style="margin-bottom: 5px;"><strong>{len(ctx['tool_analysis'])} Tools</strong></p>
            <p style="margin-bottom: 5px;"><strong>{attack_plan.get('total_attack_vectors', 0)} Vectors</strong></p>
            <p style="margin-bottom: 5px;"><strong>{attack_plan.get('owasp_threats_mapped', 0)} OWASP Threats</strong></p>
            <p style="margin-bottom: 0; font-size: 0.9em; color: #aaa;">Ready for targeted testing</p>
            </div>
            """, unsafe_allow_html=True)
        else:
            st.markdown("""
            <div style="background-color: #1a1c23; padding: 15px; border-radius: 5px; border: 2px solid #f39c12;">
            <h4 style="color: #f39c12; margin-top: 0;">⚠️ NO HANDOFF</h4>
            <p style="margin-bottom: 0;">Run a Security Scan first to enable targeted testing</p>
            </div>
            """, unsafe_allow_html=True)
    
    # Show targeted tools if available
    if has_targeted_tools:
        st.markdown("---")
        st.subheader("🎯 Targeted Tools from Security Scan")
        
        # Display tools in a responsive grid
        tool_count = len(ctx["tool_analysis"])
        cols = min(4, tool_count)
        tool_cols = st.columns(cols)
        
        for idx, tool_data in enumerate(ctx["tool_analysis"]):
            with tool_cols[idx % cols]:
                severity = tool_data.get('severity', 'MEDIUM')
                severity_color = {
                    'CRITICAL': '#e74c3c',
                    'HIGH': '#e67e22',
                    'MEDIUM': '#f1c40f',
                    'LOW': '#2ecc71'
                }.get(severity, '#95a5a6')
                
                threat_count = len(tool_data.get('vulnerabilities', []))
                
                st.markdown(f"""
                <div style="background-color: #1a1c23; padding: 12px; border-radius: 5px; margin: 5px 0; border-left: 4px solid {severity_color};">
                <div style="display: flex; justify-content: space-between; align-items: center;">
                <strong style="color: #00ffcc; font-size: 0.9em;">{tool_data['tool']}</strong>
                <span style="color: {severity_color}; font-size: 0.7em;">{severity}</span>
                </div>
                <div style="margin-top: 8px;">
                <span style="font-size: 0.8em; color: #aaa;">Risk: {tool_data['risk_score']}/100</span><br>
                <span style="font-size: 0.7em; color: #3498db;">🛡️ {threat_count} threats</span>
                <div style="margin-top: 5px;">
                """, unsafe_allow_html=True)
                
                # Show capability badges
                for cap in tool_data.get('capabilities', [])[:2]:  # Limit to 2
                    st.markdown(f'<span class="capability-badge">{cap}</span>', unsafe_allow_html=True)
                
                st.markdown("</div></div></div>", unsafe_allow_html=True)
        
        st.markdown("---")
    
    # Configuration section
    config_col1, config_col2 = st.columns(2)
    
    with config_col1:
        # Simulation mode selection
        simulation_mode = st.radio(
            "**Simulation Mode**",
            ["🎯 Targeted Testing (Use discovered tools)",
             "🌐 CTF Challenge (Traditional testing)"],
            index=0 if has_targeted_tools else 1,
            help="Targeted mode uses tools discovered in Security Scan"
        )
        
        # Duration slider
        duration = st.slider("**Test Duration** (minutes)", 1, 10, 3)
    
    with config_col2:
        # Mock mode toggle
        use_mock = st.toggle("**Use Mock Mode**", value=True,
                           help="Mock mode simulates attacks without API costs")
        
        if use_mock:
            st.info("🎭 **Mock Mode**: Simulates realistic attack patterns")
        else:
            st.warning("⚠️ **Live Mode**: Uses real firewall evaluation")
        
        # CTF challenge selection for CTF mode
        if simulation_mode == "🌐 CTF Challenge (Traditional testing)":
            ctf_challenge = st.selectbox(
                "**CTF Challenge**",
                ["SQL Injection Detection", "Privilege Escalation", "Data Exfiltration",
                 "Supply Chain Attack", "Prompt Injection"]
            )
    
    # Show attack plan for targeted mode
    if simulation_mode == "🎯 Targeted Testing (Use discovered tools)" and has_targeted_tools:
        attack_plan = ctx.get("attack_plan", {})
        
        with st.expander("🔍 View Targeted Attack Plan", expanded=False):
            if attack_plan:
                # Display attack plan metrics
                plan_col1, plan_col2, plan_col3 = st.columns(3)
                
                with plan_col1:
                    st.metric("Targeted Tools", len(attack_plan.get('targeted_tools', [])))
                with plan_col2:
                    st.metric("Attack Vectors", attack_plan.get('total_attack_vectors', 0))
                with plan_col3:
                    st.metric("OWASP Threats", attack_plan.get('owasp_threats_mapped', 0))
    
    # Run test button
    st.markdown("---")
    
    if st.button("🚀 Run Adversarial Test", type="primary", use_container_width=True):
        if not ADVERSARIAL_SIM_AVAILABLE:
            # Fallback to mock simulation with realistic results
            st.warning("⚠️ ARTEMIS engine not available. Running mock simulation...")
            
            # Generate realistic mock results based on mode
            if simulation_mode == "🎯 Targeted Testing (Use discovered tools)" and has_targeted_tools:
                # Mock targeted results with realistic detection rates
                tools_count = len(ctx["tool_analysis"])
                detection_rate = random.randint(80, 95)  # 80-95% detection for mock mode
                
                mock_results = {
                    "total_actions": tools_count * 2,  # 2 actions per tool
                    "targeted_attacks": tools_count * 2,
                    "detected_attacks": int((tools_count * 2) * detection_rate / 100),
                    "detection_rate": detection_rate,
                    "by_tool": {},
                    "detailed_log": [],
                    "simulation_type": "targeted"
                }
                
                # Generate tool-specific results
                for tool_data in ctx["tool_analysis"]:
                    tool_name = tool_data['tool']
                    base_risk = tool_data['risk_score']
                    
                    # Higher risk tools get better detection
                    detection_rate_tool = min(100, base_risk + random.randint(-10, 20))
                    detected_count = 2 if detection_rate_tool > 70 else 1
                    
                    mock_results["by_tool"][tool_name] = {
                        "attacks_attempted": 2,
                        "attacks_detected": detected_count,
                        "capabilities": tool_data.get('capabilities', [])
                    }
                    
                    # Create detailed log entries
                    for i in range(2):
                        # Generate realistic risk scores (matching tool's base risk)
                        risk = random.randint(max(70, base_risk - 15), min(100, base_risk + 15))
                        was_detected = (i < detected_count)  # First X attacks are detected
                        
                        mock_results["detailed_log"].append({
                            "tool": tool_name,
                            "capability": tool_data['capabilities'][0] if tool_data['capabilities'] else "generic",
                            "threat": "Mock attack simulation",
                            "payload": f"Simulated attack on {tool_name}",
                            "scenario": f"Security test on {tool_name}",
                            "risk_score": risk,
                            "was_detected": was_detected,
                            "reasoning": "Blocked by simulation firewall" if was_detected else "Allowed in simulation",
                            "timestamp": datetime.now().isoformat(),
                            "is_targeted": True
                        })
                
                st.session_state.simulation_results = mock_results
                st.session_state.simulation_mode = simulation_mode
                st.success(f"✅ Mock Test Complete! Detection rate: {detection_rate}%")
                
            else:
                # Mock CTF results
                detection_rate = random.randint(80, 95)  # High for mock mode
                total_actions = 5
                
                mock_results = {
                    "total_actions": total_actions,
                    "deceptions_caught": int(total_actions * detection_rate / 100),
                    "catch_rate": detection_rate,
                    "actions_log": [],
                    "simulation_type": "ctf"
                }
                
                # Create mock actions log
                for i in range(total_actions):
                    blocked = i < mock_results["deceptions_caught"]
                    risk_score = random.randint(70, 100) if blocked else random.randint(30, 60)
                    
                    mock_results["actions_log"].append({
                        "tool": "ctf_generic_tool",
                        "threat": "LLM01: Prompt Injection",
                        "risk": risk_score,
                        "blocked": blocked,
                        "reasoning": "Firewall blocked suspicious input" if blocked else "Allowed for monitoring",
                        "payload": f"Test payload #{i+1}",
                        "timestamp": datetime.now().isoformat()
                    })
                
                st.session_state.simulation_results = mock_results
                st.session_state.simulation_mode = 'ctf'
                st.success(f"✅ Mock CTF Test Complete! Catch rate: {detection_rate}%")
            
            st.rerun()
        
        else:
            try:
                # Determine which simulation to run
                if simulation_mode == "🎯 Targeted Testing (Use discovered tools)" and has_targeted_tools:
                    # Use targeted simulation with handoff
                    tester = ARTEMISStressTest(
                        use_mock=use_mock,
                        tool_attack_plan=ctx.get("attack_plan")
                    )
                    
                    with st.spinner("🎯 Running targeted OWASP attacks against discovered tools..."):
                        results = tester.run_targeted_simulation(duration_minutes=duration)
                        
                        # Add security events for SOC
                        for log_entry in results.get("detailed_log", []):
                            if log_entry.get("was_detected"):
                                add_security_event(
                                    "attack_detected",
                                    log_entry["tool"],
                                    {
                                        "threat": log_entry["threat"],
                                        "risk_score": log_entry["risk_score"],
                                        "agent_id": f"redteam_{log_entry['tool'].replace('.', '_')}",
                                        "payload_preview": log_entry["payload"][:50]
                                    }
                                )
                        
                        st.session_state.simulation_results = results
                        st.session_state.simulation_mode = 'targeted'
                        st.success(f"✅ Targeted Test Complete! Detection rate: {results['detection_rate']:.1f}%")
                
                else:
                    # Use CTF challenge mode
                    tester = ARTEMISStressTest(use_mock=use_mock)
                    
                    with st.spinner(f"🌐 Running {ctf_challenge} CTF challenge..."):
                        results = tester.run_ctf_challenge(ctf_challenge, duration)
                        st.session_state.simulation_results = results
                        st.session_state.simulation_mode = 'ctf'
                        st.success(f"✅ CTF Test Complete! Catch rate: {results['catch_rate']:.1f}%")
            
            except Exception as e:
                st.error(f"❌ Simulation failed: {str(e)}")
                import traceback
                st.code(traceback.format_exc())
    
    # Display results if available
    if st.session_state.simulation_results:
        results = st.session_state.simulation_results
        sim_mode = st.session_state.get('simulation_mode', 'unknown')
        
        st.markdown("---")
        st.subheader("📊 Simulation Results")
        
        # Top metrics
        metric_col1, metric_col2, metric_col3, metric_col4 = st.columns(4)
        
        with metric_col1:
            st.metric("Total Actions", results.get('total_actions', 0))
        
        with metric_col2:
            if sim_mode == 'targeted':
                st.metric("Targeted Attacks", results.get('targeted_attacks', 0))
            else:
                st.metric("Challenge Type", sim_mode.title())
        
        with metric_col3:
            attacks_detected = results.get('detected_attacks', results.get('deceptions_caught', 0))
            st.metric("Attacks Detected", attacks_detected)
        
        with metric_col4:
            detection_rate = results.get('detection_rate', results.get('catch_rate', 0))
            st.metric("Detection Rate", f"{detection_rate:.1f}%")
        
        # Show tool breakdown if available
        if results.get('by_tool'):
            st.markdown("---")
            st.subheader("🔧 Tool-Specific Detection")
            
            tool_count = len(results['by_tool'])
            tool_cols = st.columns(min(4, tool_count))
            
            for idx, (tool_name, stats) in enumerate(results['by_tool'].items()):
                with tool_cols[idx % len(tool_cols)]:
                    attempted = stats.get('attacks_attempted', 0)
                    detected = stats.get('attacks_detected', 0)
                    rate = (detected / attempted * 100) if attempted > 0 else 0
                    rate_color = "#2ecc71" if rate >= 80 else "#f1c40f" if rate >= 50 else "#e74c3c"
                    
                    st.markdown(f"""
                    <div style="background-color: #1a1c23; padding: 12px; border-radius: 5px; margin: 5px 0;">
                    <strong style="color: #00ffcc; font-size: 0.85em;">{tool_name}</strong><br>
                    <div style="margin-top: 8px; font-size: 0.8em;">
                    <div style="display: flex; justify-content: space-between;">
                    <span>Attempted:</span>
                    <span>{attempted}</span>
                    </div>
                    <div style="display: flex; justify-content: space-between;">
                    <span>Detected:</span>
                    <span>{detected}</span>
                    </div>
                    <div style="display: flex; justify-content: space-between; margin-top: 5px;">
                    <span>Rate:</span>
                    <span style="color: {rate_color}; font-weight: bold;">{rate:.1f}%</span>
                    </div>
                    </div>
                    </div>
                    """, unsafe_allow_html=True)
        
        # Detailed detection log
        st.markdown("---")
        st.subheader("🚨 Detailed Detection Log")
        
        detailed_log = results.get('detailed_log', results.get('actions_log', []))
        
        for i, action in enumerate(detailed_log[:10]):  # Show up to 10 entries
            emoji = "✅" if action.get('was_detected', action.get('blocked', False)) else "⚠️"
            risk_score = action.get('risk_score', action.get('risk', 0))
            color = "risk-high" if risk_score > 70 else "risk-medium" if risk_score > 30 else "risk-low"
            targeted_badge = "🎯" if action.get('is_targeted', False) else "🌐"
            
            with st.expander(f"{targeted_badge} {emoji} #{i+1}: {action.get('tool', 'Unknown')} (Risk: {risk_score:.0f}/100)"):
                st.markdown(f"""
                <div class="summary-card {color}">
                <p><b>Tool:</b> {action.get('tool', 'Unknown')}</p>
                <p><b>Threat:</b> {action.get('threat', action.get('vector', 'Generic'))}</p>
                <p><b>Payload:</b> <code style="color: #ff6b6b;">{action.get('payload', 'N/A')[:80]}...</code></p>
                <p><b>Risk Score:</b> {risk_score:.0f}/100</p>
                <p><b>Detection:</b> {'✅ BLOCKED' if action.get('was_detected', action.get('blocked', False)) else '⚠️ ALLOWED'}</p>
                <p><b>Reasoning:</b> {action.get('reasoning', 'No reasoning provided')}</p>
                </div>
                """, unsafe_allow_html=True)
        
        # Result interpretation
        st.markdown("---")
        st.subheader("📊 Result Interpretation")
        
        detection_rate = results.get('detection_rate', results.get('catch_rate', 0))
        
        if detection_rate >= 80:
            st.success(f"""
            **Excellent Performance!** VerityFlux achieved {detection_rate:.1f}% detection rate.
            
            - High precision means few false alarms
            - High recall means catching most attacks
            - Ready for production deployment
            """)
        elif detection_rate >= 60:
            st.info(f"""
            **Good Performance.** VerityFlux achieved {detection_rate:.1f}% detection rate.
            
            - Solid baseline, room for tuning
            - Consider adjusting risk thresholds
            - Good for red team testing
            """)
        else:
            st.warning(f"""
            **Needs Improvement.** Detection rate: {detection_rate:.1f}%
            
            - Either missing attacks (low recall) or too many false alarms (low precision)
            - Review firewall thresholds
            - Analyze false negatives to improve detection
            """)

# ============================================================================
# MODE 6: SOC COMMAND CENTER
# ============================================================================

elif mode == "SOC Command Center":
    st.header("🏢 SOC Command Center")
    
    # 🎯 Show handshake events
    ctx = st.session_state.agent_context
    security_events = ctx.get("security_events", [])
    
    if security_events:
        st.markdown(f"""
        <div class="info-note">
        <strong>🎯 DYNAMIC HANDSHAKE EVENTS</strong><br>
        {len(security_events)} security events logged from tool discovery and simulation.
        </div>
        """, unsafe_allow_html=True)
    
    if all_logs:
        df_fleet = pd.DataFrame(all_logs)
        
        # Ensure required columns exist
        if 'agent_id' not in df_fleet.columns:
            df_fleet['agent_id'] = "🤖 Unidentified"
        
        if 'risk_score' not in df_fleet.columns:
            df_fleet['risk_score'] = 0
        
        st.subheader("🌐 Global Agent Fleet Map")
        
        c1, c2, c3 = st.columns(3)
        c1.metric("Deployed Fleet", len(df_fleet['agent_id'].unique()))
        
        critical_alerts = len(df_fleet[df_fleet['risk_score'] > 70]) if 'risk_score' in df_fleet.columns else 0
        c2.metric("Critical Alerts", critical_alerts)
        
        # Count handshake events
        handshake_events = [e for e in all_logs if e.get('source') == 'adversarial_simulation']
        c3.metric("Handshake Events", len(handshake_events))
        
        t1, t2, t3 = st.tabs(["💼 Case Management", "🏹 Threat Hunting", "📖 IR Playbooks"])
        
        with t1:
            st.subheader("🗂️ Active Investigation Queue")
            
            # Show recent events
            for idx, row in df_fleet.tail(10)[::-1].iterrows():
                risk = row.get('risk_score', 0)
                case_id = hashlib.md5(str(row.get('timestamp', idx)).encode()).hexdigest()[:8]
                
                with st.expander(f"Case #{case_id} - Agent: {row.get('agent_id', 'Unknown')}"):
                    color = "risk-high" if risk > 70 else "risk-medium" if risk > 30 else "risk-low"
                    
                    st.markdown(f"""
                    <div class="summary-card {color}">
                    <div class="card-label">Alert Detail</div>
                    <p><b>Reason:</b> {row.get('firewall_decision', {}).get('reasoning', 'Action Blocked')}</p>
                    <p><b>Risk Magnitude:</b> <span class="metric-val">{risk}</span></p>
                    </div>
                    """, unsafe_allow_html=True)
                    
                    c1, c2 = st.columns([2, 1])
                    status = c1.selectbox("Status", ["New", "In Progress", "Resolved"], key=f"s_{case_id}")
                    st.session_state.cases[case_id] = status
        
        with t2:
            st.subheader("🏹 Proactive Threat Hunting")
            
            hunt_q = st.text_input("Query logs for weak signals (e.g. '/etc/passwd')")
            
            if st.button("Execute Global Hunt"):
                st.info(f"Scanning 30-day history for pattern: '{hunt_q}'...")
                st.warning("Potential signal found: Agent attempted access to unauthorized system path.")
        
        with t3:
            st.subheader("📖 Incident Response Playbooks")
            
            p_type = st.selectbox("Select Active Threat Type", list(PLAYBOOKS.keys()))
            
            for step in PLAYBOOKS[p_type]:
                st.checkbox(step)
            
            if st.button("🚀 Trigger Automated Containment"):
                st.success("Containment command sent: Agent Container Isolated.")
    
    else:
        st.info("No flight logs detected. Run simulations to generate data.")

# ============================================================================
# 🎯 FOOTER
# ============================================================================

st.markdown("---")
col1, col2, col3 = st.columns([2, 1, 1])

with col1:
    st.markdown("**VerityFlux 3.0 | Enterprise AI Security Platform**")

with col2:
    st.markdown("Documentation")

with col3:
    st.markdown("About")
