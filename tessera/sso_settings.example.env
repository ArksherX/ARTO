TESSERA_SSO_ENABLED=true
TESSERA_SSO_MODE=oidc
TESSERA_SSO_ROLE_CLAIM=roles
TESSERA_SSO_ADMIN_ROLES=admin,security
TESSERA_SSO_ADMIN_USERS=admin@example.com,security@example.com
TESSERA_SSO_ROLE_MAP={"\/tokens\/revoke":["security","admin"],"\/agents\/register":["admin"],"\/metrics":["security","admin","ops"],"\/access\/validate":["security","admin"]}
TESSERA_RBAC_POLICY_PATH=/etc/tessera/rbac_policy.json
TESSERA_SSO_TENANT_CLAIM=tenant_id

OIDC_ISSUER=https://example.okta.com/oauth2/default
OIDC_AUDIENCE=api://tessera
OIDC_JWKS_URL=https://example.okta.com/oauth2/default/v1/keys

# LDAP
LDAP_SERVER_URI=ldap://ldap.example.com:389
LDAP_BASE_DN=dc=example,dc=com

# SAML
SAML_SETTINGS_PATH=/etc/tessera/saml_settings.json
